{
  "name": "so-101-studio",
  "private": true,
  "description": "Browser SO-101 MuJoCo policy demo built with mujoco-react and LeRobot.",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "policy": "npm run policy:act12",
    "policy:act12": "scripts/run_policy_server.sh",
    "verify:policy": "node scripts/verify_policy_rollout.mjs",
    "verify": "npm run verify:act12",
    "verify:act12": "node scripts/verify_policy_rollout.mjs '--url=http://127.0.0.1:3001/?policy=act12' '--inference-url=http://127.0.0.1:8776/infer' --require-cameras=true --duration-ms=40000 --actions-per-request=100 --min-responses=3 --max-target-distance=0.10 --min-cube-lift=0.08 --min-target-contact-count=1 --min-gripper-contact-count=25 --min-moving-jaw-contact-count=25 --object-body=red_cube --target-body=green_target --camera-frame-dir=artifacts/act12-frames --screenshot=artifacts/act12-verify.png --report=artifacts/act12-verify.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@mujoco/mujoco": "^3.9.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-router": "^1.170.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "mujoco-react": "10.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.0.4",
    "playwright": "^1.61.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
}
